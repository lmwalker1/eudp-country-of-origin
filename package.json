{
  "name": "eudp-country-of-origin",
  "version": "2.0.0",
  "description": "EU live animals import notification service - Country of Origin",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "echo 'Build v2 - serving pre-compiled govuk-frontend assets from node_modules' && date",
    "build:dev": "webpack --config webpack.config.js --mode development",
    "dev": "npm run build:dev && node --watch src/index.js",
    "start": "node src/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@hapi/catbox-memory": "^6.0.2",
    "@hapi/crumb": "^9.0.1",
    "@hapi/hapi": "^21.4.7",
    "@hapi/inert": "^7.1.0",
    "@hapi/vision": "^7.0.3",
    "@hapi/yar": "^11.0.3",
    "accessible-autocomplete": "^3.0.1",
    "convict": "^6.2.5",
    "govuk-frontend": "^5.7.1",
    "hapi-pino": "^13.0.0",
    "joi": "^18.0.2",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.3",
    "mini-css-extract-plugin": "^2.10.1",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "terser-webpack-plugin": "^5.4.0",
    "vitest": "^3.2.4",
    "webpack": "^5.105.4",
    "webpack-assets-manifest": "^6.5.1",
    "webpack-cli": "^7.0.2"
  }
}
