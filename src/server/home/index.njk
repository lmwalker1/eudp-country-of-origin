{% extends "layouts/page.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% set pageTitle = pageTitle %}

{% block pageTitle %}{{ pageTitle }}{% endblock %}

{% block pageContent %}
  <h1 class="govuk-heading-xl">Import notification service</h1>
  <p class="govuk-body-l">Use this service to create an import notification for live animals from the EU.</p>

  {{ govukButton({
    text: "Start now",
    href: "/dashboard",
    isStartButton: true
  }) }}
{% endblock %}
